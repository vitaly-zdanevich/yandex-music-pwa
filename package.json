{
  "name": "yandex-music-pwa",
  "version": "0.3.14",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n proxy,web -c yellow,cyan \"npm:dev:proxy\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:proxy": "cargo run --manifest-path proxy/Cargo.toml",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build": "npm run typecheck && vite build",
    "build:proxy": "cargo build --manifest-path proxy/Cargo.toml --release",
    "preview": "vite preview",
    "check:version": "node scripts/check-version.mjs",
    "test": "npm run test:web && npm run test:proxy",
    "test:web": "vitest run",
    "test:web:coverage": "vitest run --coverage",
    "test:proxy": "cargo test --manifest-path proxy/Cargo.toml",
    "test:watch": "vitest"
  },
  "dependencies": {
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "3.2.7",
    "concurrently": "^9.1.2",
    "fake-indexeddb": "^6.0.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "3.2.7",
    "workbox-window": "^7.3.0"
  }
}
